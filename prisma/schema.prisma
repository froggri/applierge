generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  profile               Profile?
  jobs                  Job[]
  applications          Application[]
  documents             Document[]
  uploadedDocuments     UploadedDocument[]
  inconsistencies       ProfileInconsistency[]

  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Kandidaten-Profil (aus LinkedIn/Xing/CV extrahiert)
model Profile {
  id                 String   @id @default(cuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  fullName           String?
  headline           String?
  summary            String?
  location           String?
  linkedinUrl        String?
  xingUrl            String?
  cvPdfUrl           String?
  cvParsedJson       Json?

  salaryMin          Int?
  salaryMax          Int?
  salaryNote         String?
  workLocation       WorkLocationType?
  securityNeed       SecurityNeedLevel?
  companySizePrefs   String[]
  industryPrefs      String[]
  valuesNotes        String?
  interviewCompleted Boolean  @default(false)
  interviewData      Json?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// Gefundene / gespeicherte Stellenanzeigen
model Job {
  id               String          @id @default(cuid())
  userId           String
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  title            String
  company          String
  location         String?
  workMode         WorkLocationType?
  employmentType   EmploymentType?  // FW = Freie Wirtschaft, ÖD = Öffentlicher Dienst
  salaryMin        Int?
  salaryMax        Int?
  salaryRangeNote  String?          // Gehaltsrange aus der Anzeige als Freitext
  description      String
  url              String
  referenceId      String?          // Vorgangsnummer des Arbeitgebers
  source           String           // "stepstone", "linkedin", "xing", "manual", etc.
  postedAt         DateTime?
  expiresAt        DateTime?

  redFlags         String?          // "Haken" / Kommentar
  matchScore       Float?           // 0-100, KI-Bewertung
  matchReason      String?

  status           JobStatus        @default(INTERESTING)

  application      Application?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

// Bewerbungsstatus & Tracking pro Job
model Application {
  id               String            @id @default(cuid())
  userId           String
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId            String            @unique
  job              Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)

  status           ApplicationStatus @default(DRAFT)
  salaryStated     String?           // Gehaltsvorstellung wie angegeben
  appliedAt        DateTime?
  responseAt       DateTime?         // Datum der ersten Rückmeldung
  phoneCallAt      DateTime?         // Telefonat
  interviewAt      DateTime?         // Gesprächstermin
  followUpAt       DateTime?         // Nachhaken geplant
  notes            String?

  driveFolderUrl   String?           // Link zum Google Drive Ordner dieser Bewerbung

  documents        Document[]

  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

// Hochgeladene Quell-Dokumente (Zeugnisse, alte Anschreiben, Referenzen etc.)
model UploadedDocument {
  id            String               @id @default(cuid())
  userId        String
  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  type          UploadedDocumentType
  title         String
  fileUrl       String
  extractedText String?
  parsedJson    Json?
  analyzedAt    DateTime?

  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
}

// Erkannte Inkonsistenzen zwischen Profil-Quellen
model ProfileInconsistency {
  id           String                @id @default(cuid())
  userId       String
  user         User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  severity     InconsistencySeverity
  source1      String
  source2      String
  field        String
  description  String
  resolved     Boolean               @default(false)
  resolvedNote String?

  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
}

// KI-generierte Dokumente pro Bewerbung
model Document {
  id              String       @id @default(cuid())
  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  applicationId   String?
  application     Application? @relation(fields: [applicationId], references: [id])

  type            DocumentType
  title           String
  content         String?
  pdfUrl          String?
  driveFileUrl    String?      // optional: im Google Drive abgelegt
  generatedBy     String?      // "sonnet" | "opus"

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

enum WorkLocationType {
  ONSITE
  HYBRID
  REMOTE
  FLEXIBLE
}

enum EmploymentType {
  FW   // Freie Wirtschaft
  OD   // Öffentlicher Dienst
}

enum SecurityNeedLevel {
  LOW
  MEDIUM
  HIGH
  VERY_HIGH
}

// Workflow: INTERESTING → TO_APPLY → APPLYING → APPLIED → ...
enum JobStatus {
  INTERESTING       // gefunden, noch nicht entschieden
  TO_APPLY          // "noch zu bewerben" – aktiv in Pipeline
  IGNORED           // aussortiert
  APPLYING          // Dokumente werden erstellt
  APPLIED           // abgeschickt
  PHONE_CALL        // Telefonat vereinbart
  INTERVIEW         // Gesprächstermin
  OFFER             // Angebot erhalten
  ACCEPTED          // angenommen
  REJECTED          // abgelehnt
  WITHDRAWN         // selbst zurückgezogen
}

enum ApplicationStatus {
  DRAFT
  SENT
  ACKNOWLEDGED
  PHONE_CALL_SCHEDULED
  INTERVIEW_SCHEDULED
  OFFER_RECEIVED
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum DocumentType {
  CV_BASE
  CV_TAILORED
  COVER_LETTER
}

enum UploadedDocumentType {
  CV
  COVER_LETTER
  REFERENCE
  CERTIFICATE
  OTHER
}

enum InconsistencySeverity {
  LOW
  MEDIUM
  HIGH
}
